linux.release.x86_64 = "res://addons/godotharu/libgodothpdf.linux.template_release.x86_64.so"
windows.debug.x86_64 = "res://addons/godotharu/libgodothpdf.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://addons/godotharu/libgodothpdf.windows.template_release.x86_64.dll"
