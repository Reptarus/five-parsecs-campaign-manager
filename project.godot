; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

gut={
&"directory": PackedStringArray("res://tests/unit", "res://tests/integration", "res://tests/battle", "res://tests/performance", "res://tests/mobile", "res://tests/diagnostic"),
&"include_subdirectories": true
}

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Five Parsecs Campaign Manager"
config/version="0.1.0"
run/main_scene="res://src/ui/screens/mainmenu/MainMenu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GlobalEnums="*res://src/core/systems/GlobalEnums.gd"
GameDataManager="*res://src/core/managers/GameDataManager.gd"
DataManager="*res://src/core/data/DataManager.gd"
DLCManager="*res://src/core/systems/DLCManager.gd"
GameStateManager="*res://src/core/managers/GameStateManager.gd"
GameState="*res://src/core/state/GameState.gd"
DiceManager="*res://src/core/managers/DiceManager.gd"
SceneRouter="*res://src/ui/screens/SceneRouter.gd"
PlanetCache="*res://src/core/world/PlanetCache.gd"
WorldEconomyManager="*res://src/core/world/WorldEconomyManager.gd"
ResourceSystem="*res://src/core/systems/ResourceSystem.gd"
zzzCharacterManager="*res://src/core/character/Management/CharacterManager.gd"
zzzBattleStateMachine="*res://src/core/battle/state/BattleStateMachine.gd"
KeywordDB="*res://src/autoload/KeywordDB.gd"
TurnPhaseChecklist="*res://src/qol/TurnPhaseChecklist.gd"
CampaignJournal="*res://src/core/campaign/CampaignJournal.gd"
LegacySystem="*res://src/core/campaign/LegacySystem.gd"
NPCTracker="*res://src/core/campaign/NPCTracker.gd"
CampaignPhaseManager="*res://src/core/campaign/CampaignPhaseManager.gd"
CampaignTurnEventBus="*res://src/core/events/CampaignTurnEventBus.gd"
EquipmentManager="*res://src/core/equipment/EquipmentManager.gd"
PlanetDataManager="*res://src/core/world/PlanetDataManager.gd"
ResponsiveManager="*res://src/autoload/ResponsiveManager.gd"
ThemeManager="*res://src/ui/themes/ThemeManager.gd"
TransitionManager="res://src/autoload/TransitionManager.gd"
NotificationManager="res://src/autoload/NotificationManager.gd"

[debug]

settings/stdout/print_fps=true
settings/stdout/verbose_stdout=true
gdscript/warnings/enable=false
gdscript/warnings/unused_variable=true
gdscript/warnings/unused_signal=true
gdscript/warnings/untyped_declaration=true
gdscript/warnings/unsafe_property_access=true
gdscript/warnings/unsafe_method_access=true
gdscript/warnings/unsafe_cast=true
gdscript/warnings/unsafe_call_argument=true
gdscript/warnings/return_value_discarded=true
gdscript/warnings/treat_warnings_as_errors=false
gdscript/completion/autocomplete_setters_and_getters=true
settings/run_on_load/test_scene="res://tests/GutTestScene.tscn"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="Five Parsecs Campaign Manager"

[editor_plugins]

enabled=PackedStringArray("res://addons/gdUnit4/plugin.cfg")

[rendering]

textures/vram_compression/import_etc2_astc=true
