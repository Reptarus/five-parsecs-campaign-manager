; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Five Parsecs Campaign Manager"
config/version="0.1.0"
run/main_scene="res://src/ui/screens/mainmenu/MainMenu.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GlobalEnums="*res://src/core/systems/GlobalEnums.gd"
DataManagerAutoload="*res://src/core/data/DataManager.gd"
SystemsAutoload="*res://src/autoload/SystemsAutoload.gd"
GameStateManagerAutoload="*res://src/core/managers/GameStateManager.gd"
CharacterManagerAutoload="*res://src/core/character/Management/CharacterManager.gd"
PlanetCache="*res://src/game/world/PlanetCache.gd"
BattleStateMachineAutoload="*res://src/core/battle/state/BattleStateMachine.gd"
FPCM_AlphaGameManager="*res://src/core/managers/AlphaGameManager.gd"
CampaignManager="*res://src/core/managers/CampaignManager.gd"
DiceManager="*res://src/core/managers/DiceManager.gd"
CoreSystemSetup="*res://src/autoload/CoreSystemSetup.gd"
BattlefieldCompanionManager="*res://src/autoload/BattlefieldCompanionManager.gd"
CampaignPhaseManager="*res://src/core/campaign/CampaignPhaseManager.gd"
SaveManager="*res://src/core/state/SaveManager.gd"
GameState="*res://src/core/state/GameState.gd"
SceneRouter="*res://src/ui/screens/SceneRouter.gd"

[debug]

settings/stdout/print_fps=true
settings/stdout/verbose_stdout=true
gdscript/warnings/unused_variable=true
gdscript/warnings/unused_signal=true
gdscript/warnings/untyped_declaration=true
gdscript/warnings/unsafe_property_access=true
gdscript/warnings/unsafe_method_access=true
gdscript/warnings/unsafe_cast=true
gdscript/warnings/unsafe_call_argument=true
gdscript/warnings/return_value_discarded=true
gdscript/warnings/treat_warnings_as_errors=false
gdscript/completion/autocomplete_setters_and_getters=true

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/initial_position_type=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="Five Parsecs Campaign Manager"

[editor_plugins]

enabled=PackedStringArray("res://addons/gdUnit4/plugin.cfg")

[gdunit4]

settings/test/test_lookup_folder="tests"
ui/toolbar/run_overall=true

[input_devices]

pointing/emulate_touch_from_mouse=true

[layer_names]

2d_render/layer_1="UI"
2d_render/layer_2="Game"
2d_render/layer_3="Effects"

[rendering]

textures/vram_compression/import_etc2_astc=true
anti_aliasing/quality/msaa_2d=1
anti_aliasing/quality/msaa_3d=1
textures/decals/filter=false
textures/light_projectors/filter=false
