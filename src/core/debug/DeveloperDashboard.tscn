[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://src/core/debug/DeveloperDashboard.gd" id="1_devdash"]

[node name="DeveloperDashboard" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_devdash")

[node name="DashboardPanel" type="Panel" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -400.0
offset_top = -300.0
offset_right = 400.0
offset_bottom = 300.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="DashboardPanel"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_constants/separation = 10

[node name="Title" type="Label" parent="DashboardPanel/VBox"]
layout_mode = 2
text = "🔧 Five Parsecs Developer Dashboard"
horizontal_alignment = 1

[node name="StatusLabel" type="Label" parent="DashboardPanel/VBox"]
layout_mode = 2
size_flags_vertical = 3
text = "Loading system diagnostics..."
autowrap_mode = 3

[node name="FixButton" type="Button" parent="DashboardPanel/VBox"]
layout_mode = 2
text = "Show Scene Fix Instructions"

[node name="SceneValidatorButton" type="Button" parent="DashboardPanel/VBox"]  
layout_mode = 2
text = "Run Scene Validation"

[node name="TestCampaignButton" type="Button" parent="DashboardPanel/VBox"]
layout_mode = 2
text = "Create Test Campaign"

[node name="BypassCreationButton" type="Button" parent="DashboardPanel/VBox"]
layout_mode = 2
text = "Bypass to Dashboard"

[node name="Separator" type="HSeparator" parent="DashboardPanel/VBox"]
layout_mode = 2

[node name="WorkflowTestButton" type="Button" parent="DashboardPanel/VBox"]
layout_mode = 2
text = "🚀 Test NEW Workflow Orchestrator"

[node name="ModularScenesButton" type="Button" parent="DashboardPanel/VBox"]
layout_mode = 2
text = "🧩 Test Modular Scenes"
