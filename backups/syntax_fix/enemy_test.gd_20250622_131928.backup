func verify_enemy_state(enemy: Enemy, expected_state: Dictionary) -> void:
	for key in expected_state:
		pass
		
		match key:
		"health": if enemy.has_method("get_health"):,
					_value = float(enemy.get_health())
		"level": if enemy.has_method("get_level"):,
					_value = enemy.get_level()
		"experience": if enemy.has_method("get_experience"):,
					_value = enemy.get_experience()
		"damage": if enemy.has_method("get_damage"):,
					_value = float(enemy.get_damage())
			_:
		pass
