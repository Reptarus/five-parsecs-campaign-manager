class MockValidationPanel extends Resource:
		pass
	var is_valid: bool = false
	var validation_is_complete: bool = false
	var visible: bool = true
	var validation_message: String = ""
	var validation_state: String = "pending"
	var validation_data: Dictionary = {
		"message": "Test passed",
		"valid": true,

	#
	var error_count: int = 0
	var warning_count: int = 0
	var info_count: int = 0
	
	#
	func get_validation_message() -> String:
		return validation_message

	func set_validation_message(test_value: String) -> void:
		validation_message = test_value
		validation_message_changed.emit(validation_message)
	
	func get_validation_state() -> String:
		return validation_state

	func set_validation_state(test_value: String) -> void:
		validation_state = test_value
		validation_state_changed.emit(validation_state)
	
	func get_validation_data() -> Dictionary:
		return validation_data

	func set_validation_data(test_value: Dictionary) -> void:
		validation_data = test_value
		validation_data_changed.emit(validation_data)
	
	func get_validation_status() -> bool:
		return is_valid

	func validate() -> bool:
		is_valid = true
		validation_is_complete = true
		validation_complete.emit()
		return is_valid

	func clear_validation() -> void:
		is_valid = false
		validation_is_complete = false
		validation_message = ""
		validation_cleared.emit()
	
	#
	signal validation_complete
	signal validation_failed
	signal validation_message_changed(message: String)
	signal validation_state_changed(state: String)
	signal validation_data_changed(data: Dictionary)
	signal validation_cleared
	signal resource_updated
	signal group_created
	signal state_changed
	signal layout_changed
	signal resources_filtered
	signal resources_sorted
	signal resource_selected
	signal ui_theme_changed
	signal ui_state_changed

var mock_component: MockValidationPanel = null

func before_test() -> void:
	super.before_test()
	mock_component = MockValidationPanel.new()
	track_resource(mock_component) # Perfect cleanup

