## Five Parsecs Implementation Guidelines

### Core Rules Implementation

#### Character System
```gdscript
## Character creation following Five Parsecs Core Rules p.12-17
func create_character(background: int, motivation: int, character_class: int) -> Character:
    var character := Character.new()
    
    # Generate attributes using Five Parsecs method (2d6/3 rounded up)
    character.combat = DiceSystem.generate_attribute()
    character.reaction = DiceSystem.generate_attribute()
    character.toughness = DiceSystem.generate_attribute()
    character.savvy = DiceSystem.generate_attribute()
    character.tech = DiceSystem.generate_attribute()
    character.move = DiceSystem.generate_attribute()
    
    # Set health based on toughness (Core Rules p.13)
    character.max_health = character.toughness + 2
    character.current_health = character.max_health
    
    # Apply background and class bonuses
    _apply_background_bonuses(character, background)
    _apply_class_bonuses(character, character_class)
    
    return character
```

#### Campaign Turn Structure
```gdscript
## Implementation of Five Parsecs campaign turn sequence (Core Rules p.34-52)
class CampaignTurnManager:
    enum TurnPhase {
        UPKEEP,      # Maintenance costs, ship payments
        STORY,       # Story progression and events
        CAMPAIGN,    # Travel, patrons, jobs, world events
        BATTLE,      # Combat encounters
        RESOLUTION   # Injury recovery, loot, advancement
    }
    
    func execute_campaign_turn() -> void:
        _execute_upkeep_phase()
        _execute_story_phase()
        _execute_campaign_phase()
        if has_battle:
            _execute_battle_phase()
        _execute_resolution_phase()
```

#### Combat Resolution
```gdscript
## Combat attack resolution following Five Parsecs rules (Core Rules p.71-84)
func resolve_attack(attacker: Character, defender: Character, weapon: Weapon, distance: float) -> AttackResult:
    var result := AttackResult.new()
    
    # Base target number is 4+ (Core Rules p.75)
    var target_number := 4
    
    # Apply range modifiers
    var range_band := _determine_range_band(weapon, distance)
    match range_band:
        RangeBand.POINT_BLANK: target_number -= 1  # +1 to hit
        RangeBand.SHORT: pass                      # No modifier
        RangeBand.MEDIUM: target_number += 1       # -1 to hit
        RangeBand.LONG: target_number += 2         # -2 to hit
    
    # Apply cover penalty (+2 to target number)
    if defender.has_cover():
        target_number += 2
    
    # Roll d10 + Combat skill
    var roll := DiceSystem.d10() + attacker.combat
    
    # Determine hit success
    result.hit = roll >= target_number
    result.roll_value = roll
    result.target_number = target_number
    
    if result.hit:
        result.damage = weapon.damage_value
        # Critical hit on natural 10
        if roll - attacker.combat == 10:
            result.critical = true
            result.damage += weapon.critical_damage
    
    return result
```

### Dice System Integration
```gdscript
## Five Parsecs dice patterns implementation
class DiceSystem:
    ## Generate Five Parsecs attribute (2d6/3 rounded up)
    static func generate_attribute() -> int:
        var roll := roll_dice(2, 6)
        return ceili(float(roll) / 3.0)
    
    ## Roll d66 for tables (two d6 read as tens and ones)
    static func d66() -> int:
        var tens := randi() % 6 + 1
        var ones := randi() % 6 + 1
        return tens * 10 + ones
    
    ## Combat resolution d10
    static func d10() -> int:
        return randi() % 10 + 1
```

### Table System Implementation
```gdscript
## Pattern for Five Parsecs random tables
class TableManager:
    var _tables: Dictionary = {}
    
    func roll_on_table(table_name: String, modifiers: Dictionary = {}) -> Dictionary:
        if not _tables.has(table_name):
            _load_table(table_name)
        
        var table = _tables[table_name]
        if modifiers.size() > 0:
            return table.roll_with_modifiers(modifiers)
        else:
            return table.roll()
    
    func _load_table(table_name: String) -> void:
        var path := "res://src/data/tables/%s.json" % table_name
        _tables[table_name] = load(path)
```

## State Management

### Campaign State Validation
```gdscript
## Validates state transitions according to Five Parsecs rules
class CampaignValidator:
    func validate_phase_transition(from: CampaignPhase, to: CampaignPhase) -> ValidationResult:
        var result := ValidationResult.new()
        
        # Validate transition legality according to rulebook
        if not _is_valid_transition(from, to):
            result.valid = false
            result.error_message = "Invalid phase transition: %s -> %s" % [from, to]
            return result
        
        # Validate preconditions for target phase
        match to:
            CampaignPhase.BATTLE:
                if not _has_valid_mission():
                    result.valid = false
                    result.error_message = "Cannot enter battle without valid mission"
            CampaignPhase.RESOLUTION:
                if not _battle_completed():
                    result.valid = false
                    result.error_message = "Cannot resolve without completed battle"
        
        result.valid = true
        return result
```

