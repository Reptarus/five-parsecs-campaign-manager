## Performance Standards

### Memory Management
```gdscript
## Object pooling for frequently created objects
class BulletPool extends Node:
    var available_bullets: Array[Bullet] = []
    var active_bullets: Array[Bullet] = []
    var max_pool_size: int = 100
    
    func get_bullet() -> Bullet:
        var bullet: Bullet
        if available_bullets.size() > 0:
            bullet = available_bullets.pop_back()
        else:
            bullet = _create_bullet()
        
        active_bullets.append(bullet)
        return bullet
    
    func return_bullet(bullet: Bullet) -> void:
        active_bullets.erase(bullet)
        bullet.reset()
        
        if available_bullets.size() < max_pool_size:
            available_bullets.append(bullet)
        else:
            bullet.queue_free()
```

### Async Loading Patterns
```gdscript
## Background resource loading with progress tracking
class ResourceLoader extends Node:
    signal loading_progress(percentage: float)
    signal loading_complete(resource: Resource)
    
    func load_resource_async(path: String) -> Resource:
        ResourceLoader.load_threaded_request(path)
        
        while true:
            var status = ResourceLoader.load_threaded_get_status(path)
            match status:
                ResourceLoader.THREAD_LOAD_IN_PROGRESS:
                    var progress = ResourceLoader.load_threaded_get_status(path, true)
                    loading_progress.emit(progress[0])
                    await get_tree().process_frame
                ResourceLoader.THREAD_LOAD_LOADED:
                    var resource = ResourceLoader.load_threaded_get(path)
                    loading_complete.emit(resource)
                    return resource
                _:
                    push_error("Failed to load resource: " + path)
                    return null
```

## Testing Standards

### Unit Testing Patterns
```gdscript
## Unit test example following project standards
extends GutTest

func test_character_creation_with_valid_background():
    # Arrange
    var background = CharacterBackground.SOLDIER
    var motivation = CharacterMotivation.REVENGE
    var character_manager = CharacterManager.new()
    
    # Act
    var character = character_manager.create_character(background, motivation)
    
    # Assert
    assert_not_null(character, "Character should be created")
    assert_eq(character.background, background, "Background should be set correctly")
    assert_eq(character.motivation, motivation, "Motivation should be set correctly")
    assert_true(character.combat >= 2 and character.combat <= 6, "Combat should be in valid range")

func test_signal_emission_on_character_creation():
    # Arrange
    var character_manager = CharacterManager.new()
    var signal_emitted = false
    var created_character: Character
    
    character_manager.character_created.connect(func(char):
        signal_emitted = true
        created_character = char
    )
    
    # Act
    var character = character_manager.create_character(CharacterBackground.SOLDIER, CharacterMotivation.REVENGE)
    
    # Assert
    assert_true(signal_emitted, "character_created signal should be emitted")
    assert_same(created_character, character, "Signal should pass the created character")
```

