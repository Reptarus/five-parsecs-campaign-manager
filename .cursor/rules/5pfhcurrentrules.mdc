```gdscript
## Responsive UI component that adapts to screen size
class ResponsiveContainer extends Container:
    @export var mobile_threshold: float = 768.0
    @export var tablet_threshold: float = 1024.0
    
    func _ready() -> void:
        get_viewport().size_changed.connect(_on_viewport_resized)
        _update_layout()
    
    func _on_viewport_resized() -> void:
        _update_layout()
    
    func _update_layout() -> void:
        var viewport_size := get_viewport().get_visible_rect().size
        var width := viewport_size.x
        
        if width < mobile_threshold:
            _apply_mobile_layout()
        elif width < tablet_threshold:
            _apply_tablet_layout()
        else:
            _apply_desktop_layout()
