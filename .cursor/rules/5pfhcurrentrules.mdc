```gdscript
## Structured error handling for game systems
class GameError extends RefCounted:
    enum Type {
        INVALID_STATE,
        RESOURCE_NOT_FOUND,
        VALIDATION_FAILED,
        SYSTEM_ERROR
    }
    
    var type: Type
    var message: String
    var context: Dictionary = {}
    var recoverable: bool = true

func handle_character_creation_error(error: GameError) -> void:
    match error.type:
        GameError.Type.VALIDATION_FAILED:
            _show_validation_error(error.message)
        GameError.Type.RESOURCE_NOT_FOUND:
            _attempt_resource_recovery(error.context)
        _:
