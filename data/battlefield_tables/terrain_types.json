{
    "name": "terrain_types",
    "source": "Five Parsecs from Home Core Rules - Battlefield Environments",
    "entries": [
        {
            "roll_range": [1, 25],
            "result": {
                "type": "URBAN",
                "name": "Urban Settlement",
                "movement_modifier": 0.8,
                "cover_density": 0.7,
                "features": ["buildings", "rubble", "containers", "streets"],
                "description": "Colony settlement or outpost with buildings and urban debris."
            },
            "weight": 1.0,
            "tags": ["urban", "dense"]
        },
        {
            "roll_range": [26, 45],
            "result": {
                "type": "INDUSTRIAL",
                "name": "Industrial Zone",
                "movement_modifier": 0.7,
                "cover_density": 0.6,
                "features": ["machinery", "containers", "pipelines", "storage"],
                "description": "Industrial area with heavy machinery and cargo containers."
            },
            "weight": 0.8,
            "tags": ["industrial", "dense"]
        },
        {
            "roll_range": [46, 65],
            "result": {
                "type": "WILDERNESS",
                "name": "Wilderness",
                "movement_modifier": 0.9,
                "cover_density": 0.4,
                "features": ["rock_formations", "vegetation", "hills", "craters"],
                "description": "Open wilderness with natural terrain features."
            },
            "weight": 0.9,
            "tags": ["natural", "open"]
        },
        {
            "roll_range": [66, 80],
            "result": {
                "type": "WASTELAND",
                "name": "Wasteland",
                "movement_modifier": 0.9,
                "cover_density": 0.3,
                "features": ["wreckage", "craters", "debris_piles"],
                "description": "Barren wasteland with scattered wreckage and craters."
            },
            "weight": 0.7,
            "tags": ["wasteland", "open"]
        },
        {
            "roll_range": [81, 92],
            "result": {
                "type": "SHIP_INTERIOR",
                "name": "Ship Interior / Space Station",
                "movement_modifier": 0.6,
                "cover_density": 0.8,
                "features": ["corridors", "bulkheads", "machinery", "airlocks"],
                "description": "Interior of a starship or space station with tight corridors."
            },
            "weight": 0.5,
            "tags": ["indoor", "dense"]
        },
        {
            "roll_range": [93, 100],
            "result": {
                "type": "ALIEN_RUINS",
                "name": "Alien Ruins",
                "movement_modifier": 0.8,
                "cover_density": 0.5,
                "features": ["alien_structures", "pillars", "platforms", "debris"],
                "description": "Ancient alien ruins with unusual terrain features."
            },
            "weight": 0.4,
            "tags": ["special", "mixed"]
        }
    ],
    "validation_rules": [
        {
            "type": "mission_type_check",
            "params": {
                "RED_ZONE": {
                    "allowed_types": ["URBAN", "INDUSTRIAL", "WASTELAND"],
                    "weight_modifiers": { "URBAN": 1.5, "INDUSTRIAL": 1.3 }
                },
                "BLACK_ZONE": {
                    "allowed_types": ["SHIP_INTERIOR", "ALIEN_RUINS", "INDUSTRIAL"],
                    "weight_modifiers": { "SHIP_INTERIOR": 1.5, "ALIEN_RUINS": 1.3 }
                },
                "PATRON": {
                    "allowed_types": ["URBAN", "INDUSTRIAL", "WILDERNESS", "WASTELAND"],
                    "weight_modifiers": { "URBAN": 1.2, "INDUSTRIAL": 1.2 }
                }
            }
        }
    ],
    "modifiers": [
        {
            "type": "mission_difficulty_modifier",
            "params": {
                "EASY": { "movement_modifier": 1.1, "cover_density": 1.1 },
                "NORMAL": { "movement_modifier": 1.0, "cover_density": 1.0 },
                "HARD": { "movement_modifier": 0.9, "cover_density": 0.9 },
                "HARDCORE": { "movement_modifier": 0.8, "cover_density": 0.8 },
                "INSANITY": { "movement_modifier": 0.7, "cover_density": 0.7 }
            }
        }
    ],
    "default_result": {
        "type": "WILDERNESS",
        "name": "Basic Terrain",
        "movement_modifier": 1.0,
        "cover_density": 0.5,
        "features": ["basic_cover"],
        "description": "Standard battlefield terrain."
    }
}
