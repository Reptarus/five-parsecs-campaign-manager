        "simulation_equipment": {
          "bonus": 2,
          "description": "Advanced simulation provides superior training"
        }
      }
    },
    "RECRUIT": {
      "base_dice": "d6",
      "description": "Find potential new crew members",
      "skill_modifiers": {
        "CONNECTIONS": {
          "bonus": 1,
          "description": "Network helps find quality recruits"
        },
        "SAVVY": {
          "bonus": 1,
          "description": "Good judge of character"
        }
      },
      "equipment_modifiers": {
        "reputation_boost": {
          "bonus": 1,
          "description": "Good reputation attracts better recruits"
        }
      }
    },
    "TRACK": {
      "base_dice": "d6",
      "description": "Investigate and pursue specific targets or information",
      "skill_modifiers": {
        "SAVVY": {
          "bonus": 2,
          "description": "Investigation skills crucial for tracking"
        },
        "CONNECTIONS": {
          "bonus": 1,
          "description": "Network provides information sources"
        }
      },
      "equipment_modifiers": {
        "investigation_gear": {
          "bonus": 1,
          "description": "Professional investigation equipment"
        },
        "data_pad": {
          "bonus": 1,
          "description": "Information processing capabilities"
        }
      }
    },
    "REPAIR": {
      "base_dice": "d6",
      "description": "Maintain and repair ship systems and equipment",
      "skill_modifiers": {
        "TECH": {
          "bonus": 2,
          "description": "Technical expertise essential for repairs"
        }
      },
      "equipment_modifiers": {
        "repair_kit": {
          "bonus": 1,
          "description": "Proper tools improve repair success"
        },
        "spare_parts": {
          "bonus": 2,
          "description": "Having parts available makes repairs easier"
        },
        "workshop": {
          "bonus": 3,
          "description": "Proper workshop facilities greatly aid repairs"
