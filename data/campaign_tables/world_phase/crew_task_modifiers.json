        "SAVVY": {
          "bonus": 5,
          "description": "Better at spotting opportunities and valuable items"
        },
        "LUCK": {
          "bonus": 10,
          "description": "Lucky characters find better results"
        },
        "TECH": {
          "bonus": 3,
          "description": "Technical knowledge helps identify valuable technology"
        }
      },
      "equipment_modifiers": {
        "scanner": {
          "bonus": 5,
          "description": "Electronic scanners improve search efficiency"
        },
        "survey_tools": {
          "bonus": 10,
          "description": "Professional survey equipment greatly aids exploration"
        },
        "combat_armor": {
          "bonus": 3,
          "description": "Protection allows exploration of dangerous areas"
        }
      }
    },
    "TRADE": {
      "base_dice": "d6",
      "description": "Engage in commercial activities for profit",
      "skill_modifiers": {
        "SAVVY": {
          "bonus": 1,
          "description": "Better at identifying profitable deals"
        },
        "CONNECTIONS": {
          "bonus": 1,
          "description": "Network contacts provide trading opportunities"
        }
      },
      "equipment_modifiers": {
        "trade_goods": {
          "bonus": 1,
          "description": "Having goods to trade improves prospects"
        },
        "luxury_items": {
          "bonus": 2,
          "description": "High-value items command premium prices"
        },
        "cargo_hold": {
          "bonus": 1,
          "description": "Larger capacity enables bulk trading"
        }
      }
    },
    "FIND_PATRON": {
      "base_dice": "2d6",
      "description": "Seek out patrons offering job opportunities",
      "skill_modifiers": {
        "CONNECTIONS": {
          "bonus": 2,
          "description": "Network connections lead to patron contacts"
        },
        "SAVVY": {
          "bonus": 1,
          "description": "Social awareness helps locate potential patrons"
        }
      },
      "equipment_modifiers": {
        "formal_wear": {
          "bonus": 1,
          "description": "Proper attire improves first impressions"
        },
        "communicator": {
          "bonus": 1,
          "description": "Better communication equipment helps networking"
        }
      }
    },
    "TRAIN": {
      "base_dice": "d6",
      "description": "Improve skills and abilities through practice",
      "skill_modifiers": {
        "existing_skill_level": {
          "penalty": -1,
          "per_level": true,
          "description": "Higher skill levels are harder to improve"
