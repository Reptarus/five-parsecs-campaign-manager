      },
      "equipment_modifiers": {
        "false_documents": {
          "bonus": 2,
          "description": "Fake IDs and papers support deception"
        },
        "disguise_kit": {
          "bonus": 1,
          "description": "Disguises help avoid recognition"
        }
      }
    }
  },
  "universal_modifiers": {
    "world_type_modifiers": {
      "TRADE_HUB": {
        "TRADE": 2,
        "FIND_PATRON": 1,
        "description": "Trade hubs offer commercial opportunities"
      },
      "INDUSTRIAL": {
        "TRADE": 1,
        "REPAIR": 1,
        "RECRUIT": 1,
        "description": "Industrial worlds need materials and have skilled workers"
      },
      "FRONTIER": {
        "EXPLORE": 10,
        "FIND_PATRON": -1,
        "RECRUIT": -1,
        "description": "Frontier worlds offer exploration but limited civilization"
      },
      "CAPITAL": {
        "FIND_PATRON": 2,
        "TRAIN": 1,
        "RECRUIT": 1,
        "description": "Capital worlds have many opportunities and resources"
      },
      "BACKWATER": {
        "FIND_PATRON": -2,
        "TRADE": -1,
        "TRAIN": -1,
        "description": "Backwater worlds offer limited opportunities"
      },
      "DANGEROUS": {
        "EXPLORE": 5,
        "RECRUIT": -1,
        "description": "Dangerous worlds hide treasures but deter recruits"
      },
      "HIGH_TECH": {
        "REPAIR": 2,
        "TRAIN": 1,
        "EXPLORE": 5,
        "description": "High-tech worlds offer advanced facilities and equipment"
      },
      "LOW_TECH": {
        "REPAIR": -2,
        "TRAIN": -1,
        "description": "Low-tech worlds lack modern facilities"
      }
    },
    "crew_status_modifiers": {
      "injured_crew": {
        "penalty": -1,
        "description": "Injured crew members are less effective at tasks"
      },
      "well_equipped": {
        "bonus": 1,
        "description": "Having proper equipment improves all tasks"
      },
      "veteran_crew": {
        "bonus": 1,
        "threshold": "average_level_3",
        "description": "Experienced crew performs better"
      }
    },
    "reputation_modifiers": {
      "excellent_reputation": {
        "threshold": 25,
        "FIND_PATRON": 2,
        "RECRUIT": 2,
        "description": "Excellent reputation opens many doors"
      },
      "good_reputation": {
        "threshold": 10,
        "FIND_PATRON": 1,
        "RECRUIT": 1,
        "description": "Good reputation provides advantages"
      },
      "poor_reputation": {
        "threshold": -5,
        "FIND_PATRON": -1,
        "RECRUIT": -1,
        "description": "Poor reputation limits opportunities"
      },
      "terrible_reputation": {
        "threshold": -15,
        "FIND_PATRON": -2,
        "RECRUIT": -2,
        "description": "Terrible reputation creates significant obstacles"
      }
    }
  },
  "special_rules": {
    "multiple_crew_same_task": {
      "rule": "Only one crew member per task type per turn unless specified",
      "exceptions": ["EXPLORE", "TRADE"],
      "description": "Most tasks can only be attempted once per turn"
    },
    "crew_limitations": {
      "rule": "Injured crew cannot perform tasks requiring physical activity",
      "affected_tasks": ["EXPLORE", "REPAIR"],
      "description": "Physical condition affects task capability"
    },
    "world_restrictions": {
      "rule": "Some worlds may restrict certain activities",
      "examples": ["No trading on blockaded worlds", "No recruitment in quarantine zones"],
      "description": "World conditions can prevent certain tasks"
    }
  }
}