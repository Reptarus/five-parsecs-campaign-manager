{
  "name": "Injury Tables",
  "version": "3.0",
  "source": "Five Parsecs from Home Core Rules p.119",
  "dice_type": "d100",
  "description": "Roll for each character that became a casualty. Bot/Soulless use Bot Injury Table. Knocked out (3 Stun) characters skip this roll.",
  "rules": {
    "luck_override": "If a character with Luck would be slain, they survive but lose ALL Luck points immediately.",
    "damaged_equipment": "Damaged equipment cannot be used until Repaired (p.78).",
    "knocked_out_skip": "Characters knocked out from 3 simultaneous Stun results do not roll."
  },
  "injury_tables": {
    "human_injury_table": [
      {
        "roll_range": [1, 5],
        "name": "Gruesome fate",
        "effects": [
          "Character is dead",
          "All carried equipment is damaged"
        ],
        "recovery_time": 0,
        "dead": true
      },
      {
        "roll_range": [6, 15],
        "name": "Death or permanent injury",
        "effects": [
          "Dead, or removed from the campaign"
        ],
        "recovery_time": 0,
        "dead": true
      },
      {
        "roll_range": [16, 16],
        "name": "Miraculous escape",
        "effects": [
          "Character survives and receives +1 Luck",
          "All items carried are permanently lost"
        ],
        "luck_bonus": 1,
        "recovery_time": 0,
        "dead": false
      },
      {
        "roll_range": [17, 30],
        "name": "Equipment loss",
        "effects": [
          "Random carried item is damaged"
        ],
        "recovery_time": 0,
        "dead": false
      },
      {
        "roll_range": [31, 45],
        "name": "Crippling wound",
        "effects": [
          "Require 1D6 credits of surgery immediately",
          "Or suffer -1 permanent reduction to highest of Speed or Toughness"
        ],
        "surgery_cost": "1d6",
        "stat_reduction": {
          "stats": ["speed", "toughness"],
          "pick": "highest",
          "amount": -1
        },
        "recovery_time": "1d6",
        "dead": false
      },
      {
        "roll_range": [46, 54],
        "name": "Serious injury",
        "effects": [
          "No long-term effect"
        ],
        "recovery_time": "1d3+1",
        "dead": false
      },
      {
        "roll_range": [55, 80],
        "name": "Minor injuries",
        "effects": [
          "No long-term effect"
        ],
        "recovery_time": 1,
        "dead": false
      },
      {
        "roll_range": [81, 95],
        "name": "Knocked out",
        "effects": [
          "No long-term effect"
        ],
        "recovery_time": 0,
        "dead": false
      },
      {
        "roll_range": [96, 100],
        "name": "School of hard knocks",
        "effects": [
          "Earn 1 XP"
        ],
        "xp_bonus": 1,
        "recovery_time": 0,
        "dead": false
      }
    ],
    "bot_injury_table": [
      {
        "roll_range": [1, 5],
        "name": "Obliterated",
        "effects": [
          "Destroyed",
          "All carried equipment is damaged"
        ],
        "repair_time": 0,
        "destroyed": true
      },
      {
        "roll_range": [6, 15],
        "name": "Destroyed",
        "effects": [
          "Destroyed"
        ],
        "repair_time": 0,
        "destroyed": true
      },
      {
        "roll_range": [16, 30],
        "name": "Equipment loss",
        "effects": [
          "Random carried item is damaged"
        ],
        "repair_time": 0,
        "destroyed": false
      },
      {
        "roll_range": [31, 45],
        "name": "Severe damage",
        "effects": [
          "No long-term effect"
        ],
        "repair_time": "1d6",
        "destroyed": false
      },
      {
        "roll_range": [46, 65],
        "name": "Minor damage",
        "effects": [
          "No long-term effect"
        ],
        "repair_time": 1,
        "destroyed": false
      },
      {
        "roll_range": [66, 100],
        "name": "Just a few dents",
        "effects": [
          "No long-term effect"
        ],
        "repair_time": 0,
        "destroyed": false
      }
    ]
  },
  "xp_table": {
    "source": "Core Rules p.119",
    "description": "XP awards for battle participants. Bots do not receive XP.",
    "awards": [
      {"condition": "Became a casualty", "xp": 1},
      {"condition": "Survived, but did not Win", "xp": 2},
      {"condition": "Survived and Won", "xp": 3},
      {"condition": "First character to inflict a casualty", "xp": 1},
      {"condition": "Killed Unique Individual", "xp": 1},
      {"condition": "Campaign is on Easy mode", "xp": 1}
    ]
  }
}
