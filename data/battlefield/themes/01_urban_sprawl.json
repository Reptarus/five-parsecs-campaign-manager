{
  "name": "Urban Sprawl",
  "description": "A dense city block with tight alleys and multi-level buildings.",
  "generation_pipeline": [
    {
      "action": "fill_background",
      "params": { "feature_tag": "pavement" }
    },
    {
      "action": "place_large_features",
      "params": { "feature_tag": "building_urban", "count": "1d3+2", "min_distance": 4 }
    },
    {
      "action": "add_scatter",
      "params": { "feature_tag": "urban_clutter", "density": 0.3, "zone": "outside_buildings" }
    },
    {
      "action": "place_objectives",
      "params": { "objective_tag": "urban_terminal", "count": 2, "placement_rule": "in_buildings" }
    },
    {
      "action": "run_validation",
      "params": { "rulesets": ["standard_tactical", "urban_specific"] }
    }
  ]
}
