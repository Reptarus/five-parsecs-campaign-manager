{
	"races": [
		{
			"id": "human",
			"name": "Human",
			"description": "The most common species in Unified Space. Adaptable and found everywhere.",
			"base_stats": {
				"reactions": 1,
				"speed": 4,
				"combat_skill": 0,
				"toughness": 3,
				"savvy": 0
			},
			"special_rules": [
				"Can exceed 1 point of Luck"
			],
			"lore": "Humans are found on almost every world across Unified Space. Their adaptability is their greatest strength."
		},
		{
			"id": "engineer",
			"name": "Engineer",
			"description": "Cybernetically enhanced humans with innate understanding of technology.",
			"base_stats": {
				"reactions": 1,
				"speed": 4,
				"combat_skill": 0,
				"toughness": 2,
				"savvy": 1
			},
			"special_rules": [
				"Toughness cannot exceed 4",
				"When using repair kits, roll twice and pick the better result"
			],
			"lore": "Engineers are humans who have undergone extensive cybernetic enhancement, integrating technology into their nervous systems."
		},
		{
			"id": "kerin",
			"name": "K'Erin",
			"description": "Hulking aliens with a natural affinity for close combat.",
			"base_stats": {
				"reactions": 1,
				"speed": 4,
				"combat_skill": 0,
				"toughness": 4,
				"savvy": 0
			},
			"special_rules": [
				"Roll twice in Brawling and pick the better result",
				"If able to Brawl an opponent, must do so"
			],
			"lore": "The K'Erin are a proud warrior race known for their physical prowess and code of honor."
		},
		{
			"id": "soulless",
			"name": "Soulless",
			"description": "Mysterious cybernetic beings connected to a hive intelligence.",
			"base_stats": {
				"reactions": 1,
				"speed": 4,
				"combat_skill": 0,
				"toughness": 4,
				"savvy": 1
			},
			"special_rules": [
				"6+ Armor Saving Throw",
				"Use Bot injury table",
				"Cannot use Consumables",
				"Cannot use Implants"
			],
			"lore": "The Soulless are cybernetic species connected to a hive intelligence. Individual units maintain autonomy but share information across their network."
		},
		{
			"id": "precursor",
			"name": "Precursor",
			"description": "Ancient race with advanced knowledge and mysterious abilities.",
			"base_stats": {
				"reactions": 1,
				"speed": 5,
				"combat_skill": 0,
				"toughness": 2,
				"savvy": 0
			},
			"special_rules": [
				"Roll one extra Character Event each campaign turn"
			],
			"lore": "The Precursors are an ancient species that explored the stars when most other races were still primitive."
		},
		{
			"id": "feral",
			"name": "Feral",
			"description": "Genetically engineered humanoid-animal hybrids.",
			"base_stats": {
				"reactions": 1,
				"speed": 4,
				"combat_skill": 0,
				"toughness": 3,
				"savvy": 0
			},
			"special_rules": [
				"Roll 1D6+1 for initiative (instead of 1D6)"
			],
			"lore": "Ferals were originally created as specialized soldiers, combining human intelligence with animal traits."
		},
		{
			"id": "swift",
			"name": "Swift",
			"description": "Diminutive, winged humanoids with exceptional mobility.",
			"base_stats": {
				"reactions": 1,
				"speed": 5,
				"combat_skill": 0,
				"toughness": 3,
				"savvy": 0
			},
			"special_rules": [
				"Can Dash 3\" and fire without penalty",
				"Never suffer falling damage",
				"When shot at, may opt to move 1\" in any direction before the Hit is resolved"
			],
			"lore": "The Swift are diminutive, winged humanoids known for their erratic, jerky movements and ability to glide."
		},
		{
			"id": "bot",
			"name": "Bot",
			"description": "Autonomous robotic units with specialized programming.",
			"base_stats": {
				"reactions": 2,
				"speed": 4,
				"combat_skill": 1,
				"toughness": 4,
				"savvy": 2
			},
			"special_rules": [
				"6+ Armor Saving Throw",
				"Use Bot injury table",
				"Cannot earn XP",
				"Cannot use Consumables",
				"Cannot use Implants",
				"Do not roll Character Events",
				"Do not receive Luck if selected as Leader"
			],
			"lore": "Bots come in countless configurations. Some advanced models develop a form of sentience over time."
		}
