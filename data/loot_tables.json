{
  "name": "Main Loot Table",
  "version": "3.0",
  "source": "Five Parsecs from Home Core Rules p.70-72",
  "dice_type": "d100",
  "description": "Roll D100 on Main Loot Table for each loot opportunity earned.",
  "tables": {
    "main_loot": [
      {
        "roll_range": [1, 25],
        "category": "WEAPON",
        "description": "Single weapon (roll weapon subtable)"
      },
      {
        "roll_range": [26, 35],
        "category": "DAMAGED_WEAPONS",
        "description": "2 damaged weapons (need repair)",
        "requires_repair": true,
        "count": 2
      },
      {
        "roll_range": [36, 45],
        "category": "DAMAGED_GEAR",
        "description": "2 damaged gear items (need repair)",
        "requires_repair": true,
        "count": 2
      },
      {
        "roll_range": [46, 65],
        "category": "GEAR",
        "description": "Single gear item (roll gear subtable)"
      },
      {
        "roll_range": [66, 80],
        "category": "ODDS_AND_ENDS",
        "description": "Odds and ends item (roll subtable)"
      },
      {
        "roll_range": [81, 100],
        "category": "REWARDS",
        "description": "Rewards (roll rewards subtable)"
      }
    ],
    "weapon_subtable": [
      {"roll_range": [1, 35], "category": "basic_weapons", "items": ["Hand Gun", "Military Rifle", "Shotgun", "Auto Rifle"]},
      {"roll_range": [36, 50], "category": "energy_weapons", "items": ["Hand Laser", "Infantry Laser", "Blast Rifle"]},
      {"roll_range": [51, 65], "category": "plasma_weapons", "items": ["Plasma Rifle", "Fury Rifle", "Needle Rifle"]},
      {"roll_range": [66, 85], "category": "melee_weapons", "items": ["Blade", "Ripper Sword", "Boarding Saber"]},
      {"roll_range": [86, 100], "category": "grenades", "items": ["3 Frakk Grenades", "2 Dazzle Grenades", "2 Shock Grenades"]}
    ],
    "gear_subtable": [
      {"roll_range": [1, 20], "category": "gun_mods", "items": ["Assault Blade", "Bipod", "Stabilizer", "Laser Sight", "Heavy Duty Magazine"]},
      {"roll_range": [21, 40], "category": "gun_sights", "items": ["Laser Sight", "Quality Sight", "Seeker Sight", "Night Sight"]},
      {"roll_range": [41, 75], "category": "protective_items", "items": ["Combat Armor", "Frag Vest", "Flak Screen", "Deflector Field", "Shield Generator"]},
      {"roll_range": [76, 100], "category": "utility_items", "items": ["Motion Tracker", "Jump Belt", "Battle Visor", "Scanner Bot", "Communicator", "Grapple Launcher"]}
    ],
    "odds_and_ends_subtable": [
      {"roll_range": [1, 55], "category": "consumables", "items": ["Booster Pills", "Combat Serum", "Stim-pack", "Rage Out", "Still"], "uses": 2},
      {"roll_range": [56, 70], "category": "implants", "items": ["Boosted Arm", "Boosted Leg", "Health Boost", "Night Sight", "Pain Suppressor", "Neural Optimization"]},
      {"roll_range": [71, 100], "category": "ship_items", "items": ["Med-patch", "Spare Parts", "Repair Bot", "Nano-doc", "Colonist Ration Packs", "Fuel Cell"]}
    ],
    "rewards_subtable": [
      {"roll_range": [1, 10], "item": "Documents", "rumors": 1},
      {"roll_range": [11, 20], "item": "Data Files", "rumors": 2},
      {"roll_range": [21, 25], "item": "Scrap", "credits": 3},
      {"roll_range": [26, 40], "item": "Cargo Crate", "credits_dice": "1d6"},
      {"roll_range": [41, 55], "item": "Valuable Materials", "credits_dice": "1d6+2"},
      {"roll_range": [56, 70], "item": "Rare Substance", "credits_dice": "2d6_pick_highest"},
      {"roll_range": [71, 85], "item": "Ship Parts", "discount_dice": "1d6"},
      {"roll_range": [86, 90], "item": "Military Ship Part", "discount_dice": "1d6+2"},
      {"roll_range": [91, 95], "item": "Mysterious Items", "story_points": 2},
      {"roll_range": [96, 100], "item": "Personal Item", "story_points": 3}
    ]
  }
}
