{
  "name": "Main Loot Table",
  "version": "3.0",
  "source": "Five Parsecs from Home Core Rules pp.131-133",
  "dice_type": "d100",
  "description": "Roll D100 on Main Loot Table for each loot opportunity earned.",
  "tables": {
    "main_loot": [
      {
        "roll_range": [1, 25],
        "category": "WEAPON",
        "description": "Single weapon (roll weapon subtable)"
      },
      {
        "roll_range": [26, 35],
        "category": "DAMAGED_WEAPONS",
        "description": "2 damaged weapons (need repair)",
        "requires_repair": true,
        "count": 2
      },
      {
        "roll_range": [36, 45],
        "category": "DAMAGED_GEAR",
        "description": "2 damaged gear items (need repair)",
        "requires_repair": true,
        "count": 2
      },
      {
        "roll_range": [46, 65],
        "category": "GEAR",
        "description": "Single gear item (roll gear subtable)"
      },
      {
        "roll_range": [66, 80],
        "category": "ODDS_AND_ENDS",
        "description": "Odds and ends item (roll subtable)"
      },
      {
        "roll_range": [81, 100],
        "category": "REWARDS",
        "description": "Rewards (roll rewards subtable)"
      }
    ],
    "weapon_subtable": [
      {"roll_range": [1, 35], "category": "slug_weapons", "items": ["Hold Out Pistol", "Hand Gun", "Scrap Pistol", "Machine Pistol", "Duelling Pistol", "Hand Cannon", "Colony Rifle", "Military Rifle", "Shotgun", "Flak Gun", "Hunting Rifle", "Marksman's Rifle", "Auto Rifle", "Rattle Gun"]},
      {"roll_range": [36, 50], "category": "energy_weapons", "items": ["Hand Laser", "Beam Pistol", "Infantry Laser", "Blast Pistol", "Blast Rifle", "Hyper Blaster"]},
      {"roll_range": [51, 65], "category": "special_weapons", "items": ["Needle Rifle", "Plasma Rifle", "Fury Rifle", "Shell Gun", "Cling Fire Pistol", "Hand Flamer"]},
      {"roll_range": [66, 85], "category": "melee_weapons", "items": ["Blade", "Brutal Melee Weapon", "Boarding Saber", "Ripper Sword", "Shatter Axe", "Power Claw", "Glare Sword", "Suppression Maul"]},
      {"roll_range": [86, 100], "category": "grenades", "items": ["3 Frakk Grenades", "3 Dazzle Grenades"]}
    ],
    "gear_subtable": [
      {"roll_range": [1, 20], "category": "gun_mods", "items": ["Assault Blade", "Beam Light", "Bipod", "Hot Shot Pack", "Cyber-configurable Nano-Sludge", "Stabilizer", "Shock Attachment", "Upgrade Kit"]},
      {"roll_range": [21, 40], "category": "gun_sights", "items": ["Laser Sight", "Quality Sight", "Seeker Sight", "Tracker Sight", "Unity Battle Sight"]},
      {"roll_range": [41, 75], "category": "protective_items", "items": ["Battle Dress", "Camo Cloak", "Combat Armor", "Deflector Field", "Flak Screen", "Flex-Armor", "Frag Vest", "Screen Generator", "Stealth Gear"]},
      {"roll_range": [76, 100], "category": "utility_items", "items": ["Auto Sensor", "Battle Visor", "Communicator", "Concealed Blade", "Displacer", "Distraction Bot", "Grapple Launcher", "Grav Dampener", "Hazard Suit", "Hover Board", "Insta-Wall", "Jump Belt", "Motion Tracker", "Multi-Cutter", "Robo-Rabbit's Foot", "Scanner Bot", "Snooper Bot", "Sonic Emitter", "Steel Boots", "Time Distorter"]}
    ],
    "odds_and_ends_subtable": [
      {"roll_range": [1, 55], "category": "consumables", "items": ["Booster Pills", "Combat Serum", "Kiranin Crystals", "Rage Out", "Still", "Stim-pack"], "uses": 2},
      {"roll_range": [56, 70], "category": "implants", "items": ["AI Companion", "Body Wire", "Boosted Arm", "Boosted Leg", "Cyber Hand", "Genetic Defenses", "Health Boost", "Nerve Adjuster", "Neural Optimization", "Night Sight", "Pain Suppressor"]},
      {"roll_range": [71, 100], "category": "ship_items", "items": ["Analyzer", "Colonist Ration Packs", "Duplicator", "Fake ID", "Fixer", "Genetic Reconfiguration Kit", "Loaded Dice", "Lucky Dice", "Mk II Translator", "Med-patch", "Meditation Orb", "Nano-doc", "Novelty Stuffed Animal", "Purifier", "Repair Bot", "Sector Permit", "Spare Parts", "Teach-Bot", "Transcender"]}
    ],
    "rewards_subtable": [
      {"roll_range": [1, 10], "item": "Documents", "rumors": 1},
      {"roll_range": [11, 20], "item": "Data Files", "rumors": 2},
      {"roll_range": [21, 25], "item": "Scrap", "credits": 3},
      {"roll_range": [26, 40], "item": "Cargo Crate", "credits_dice": "1d6"},
      {"roll_range": [41, 55], "item": "Valuable Materials", "credits_dice": "1d6+2"},
      {"roll_range": [56, 70], "item": "Rare Substance", "credits_dice": "2d6_pick_highest"},
      {"roll_range": [71, 85], "item": "Ship Parts", "discount_dice": "1d6"},
      {"roll_range": [86, 90], "item": "Military Ship Part", "discount_dice": "1d6+2"},
      {"roll_range": [91, 95], "item": "Mysterious Items", "story_points": 2},
      {"roll_range": [96, 100], "item": "Personal Item", "story_points": 3}
    ],
    "battlefield_finds": [
      {"roll_range": [1, 15], "category": "WEAPON", "description": "Random weapon from slain enemy"},
      {"roll_range": [16, 25], "category": "CONSUMABLE", "description": "Usable goods (consumable item)"},
      {"roll_range": [26, 35], "category": "QUEST_RUMOR", "description": "Curious data stick", "quest_rumor": true},
      {"roll_range": [36, 45], "category": "SHIP_PART", "description": "Starship part", "credits": 2},
      {"roll_range": [46, 60], "category": "TRINKET", "description": "Personal trinket (possible future loot roll)"},
      {"roll_range": [61, 75], "category": "DEBRIS", "description": "Debris (1D3 credits)", "dice": "1d3"},
      {"roll_range": [76, 90], "category": "VITAL_INFO", "description": "Vital info (Corporate Patron opportunity)"},
      {"roll_range": [91, 100], "category": "NOTHING", "description": "Nothing of value"}
    ]
  },
