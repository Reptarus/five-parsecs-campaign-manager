# Godot 4+ specific ignores
.godot/

# Godot-specific ignores
.import/
export.cfg
export_presets.cfg
*.translation

# Builds and exports
/android/
/builds/
/build/
/dist/
*.apk
*.idsig
*.pck
*.exe

# Project-local secrets (never commit)
.env.local
addons/talo/settings.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
*.tmp

# Native binaries — plugin libs, Steam SDK, export templates
*.dll
*.so
*.dylib
*.aar
*.framework
*.xcframework

# Large art assets (not source code)
Assets/BookImages/

# PSD extraction recovery cache (raw per-layer dumps; categorized copies live
# alongside in bg/, actors/, fx/, props/ and ARE committed)
assets/scenes/*/_raw/

# Third-party addons with large binary content
addons/curved_lines_2d/

# System/tool-specific ignores
.DS_Store
*~
*.blend1
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Project specific ignores
override.cfg
*.save
*.bak
node_modules

# Dev artifacts - prevent root clutter
/reports/
/scripts/
/tools/
/mcp-servers/
/screenshot/
package-lock.json
*.mdc

# Test output dumps
test_*_output.txt
test_results.txt
test_e2e_*.txt
test_full_run.txt
.mcp/

# Installers / tooling binaries (never commit)
*.msi
*.exe

