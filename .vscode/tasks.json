{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "type": "process",
            "command": "C:\\Users\\admin\\Desktop\\Godot_v4.6-stable_win64.exe\\Godot_v4.6-stable_win64_console.exe",
            "args": [
                "--headless",
                "--quit",
                "--path",
                "${workspaceFolder}"
            ],
            "problemMatcher": {
                "owner": "godot",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}"
                ],
                "pattern": {
                    "regexp": "^\\s*(.*):(\\d+):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "message": 3
                }
            }
        },
        {
            "label": "run-tests",
            "type": "process",
            "command": "C:\\Users\\admin\\Desktop\\Godot_v4.6-stable_win64.exe\\Godot_v4.6-stable_win64_console.exe",
            "args": [
                "--path",
                "${workspaceFolder}",
                "--headless",
                "--script",
                "addons/gdUnit4/bin/GdUnitCmdTool.gd",
                "-a",
                "tests/unit/",
                "--quit-after",
                "120"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": {
                "owner": "godot-test",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}"
                ],
                "pattern": {
                    "regexp": "^\\s*(.*):(\\d+):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "message": 3
                }
            }
        },
        {
            "label": "run-current-test",
            "type": "process",
            "command": "C:\\Users\\admin\\Desktop\\Godot_v4.6-stable_win64.exe\\Godot_v4.6-stable_win64_console.exe",
            "args": [
                "--path",
                "${workspaceFolder}",
                "--headless",
                "--script",
                "addons/gdUnit4/bin/GdUnitCmdTool.gd",
                "-a",
                "${file}",
                "--quit-after",
                "60"
            ],
            "problemMatcher": {
                "owner": "godot-test",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}"
                ],
                "pattern": {
                    "regexp": "^\\s*(.*):(\\d+):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "message": 3
                }
            }
        }
    ]
}
