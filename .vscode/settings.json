{
    "godot.editorPath": "C:\\Users\\admin\\Desktop\\Godot_v4.6-stable_win64.exe\\Godot_v4.6-stable_win64_console.exe",
    "godotTools.editorPath.godot4": "C:\\Users\\admin\\Desktop\\Godot_v4.6-stable_win64.exe\\Godot_v4.6-stable_win64_console.exe",
    "godot.editor.port": 6007,
    "godot.editor.host": "127.0.0.1",
    "godot.editor.showOutputOnStart": false,
    "godot.editor.reconnectOnStart": false,
    "godot.lsp.serverPort": 6005,
    "godot.lsp.useDefaultHost": true,
    "godot.lsp.useDefaultPort": true,
    "godot.lsp.enableDiagnostics": true,
    "godot.lsp.enableSignatureHelp": true,
    "godot.lsp.enableHover": true,
    "godot.lsp.enableCompletions": true,
    "godot.lsp.checkOnSave": true,
    "godot.lsp.checkOnType": true,
    "godot.lsp.checkOnChange": false,
    "debug.openDebug": "openOnDebugBreak",
    "debug.internalConsoleOptions": "openOnSessionStart",
    "debug.console.closeOnEnd": false,
    "debug.showInStatusBar": "always",
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "source": "PowerShell",
            "icon": "terminal-powershell",
            "path": "${env:windir}\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
            "args": [
                "-NoLogo",
                "-NoExit",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "Set-Location -LiteralPath '${workspaceFolder}'"
            ]
        }
    },
    "terminal.integrated.env.windows": {
        "GODOT_PATH": "${env:GODOT_PATH}",
        "PROJECT_ROOT": "${workspaceFolder}"
    },
    "terminal.integrated.cwd": "${workspaceFolder}",
    "terminal.integrated.shellArgs.windows": [],
    "terminal.integrated.persistentSessionReviveProcess": "never",
    "terminal.integrated.enablePersistentSessions": false,
    "terminal.integrated.gpuAcceleration": "off",
    "terminal.integrated.windowsEnableConpty": false,
    "terminal.integrated.defaultLocation": "editor",
    "terminal.integrated.showExitAlert": false,
    "terminal.integrated.allowChords": false,
    "terminal.integrated.copyOnSelection": false,
    "terminal.integrated.environmentChangesIndicator": "off",
    "terminal.integrated.inheritEnv": true,
    "accessibility.signals.terminalBell": {
        "sound": "off"
    },
    "terminal.integrated.enableVisualBell": false,
    "problems.decorations.enabled": true,
    "problems.autoReveal": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": false,
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit"
    },
    "files.associations": {
        "*.gd": "gdscript"
    },
    "files.watcherExclude": {
        "**/.godot/**": true,
        "**/.mcp/**": true,
        "**/node_modules/**": true,
        "**/mcp-servers/**": true
    }
}
